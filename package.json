{
  "name": "repolens",
  "displayName": "RepoLens",
  "description": "Use any GitHub repository as RAG context for Copilot — query codebases, docs, and institutional knowledge without leaving VS Code.",
  "version": "0.0.1",
  "publisher": "repolens",
  "repository": {
    "type": "git",
    "url": "https://github.com/colbymk97/repo-lens.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "copilot",
    "rag",
    "github",
    "context",
    "search"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repoLens.addRepository",
        "title": "RepoLens: Add Repository"
      },
      {
        "command": "repoLens.removeRepository",
        "title": "RepoLens: Remove Repository"
      },
      {
        "command": "repoLens.syncDataSource",
        "title": "RepoLens: Sync Data Source"
      },
      {
        "command": "repoLens.syncAllDataSources",
        "title": "RepoLens: Sync All Data Sources"
      },
      {
        "command": "repoLens.setApiKey",
        "title": "RepoLens: Set OpenAI API Key"
      },
      {
        "command": "repoLens.editTool",
        "title": "RepoLens: Edit Tool"
      },
      {
        "command": "repoLens.syncDataSourceFromTree",
        "title": "Sync",
        "icon": "$(sync)"
      },
      {
        "command": "repoLens.removeDataSourceFromTree",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "repoLens.editToolFromTree",
        "title": "Edit",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "repoLens.syncDataSourceFromTree",
          "when": "view == repoLens.dataSources && viewItem == dataSource",
          "group": "inline"
        },
        {
          "command": "repoLens.removeDataSourceFromTree",
          "when": "view == repoLens.dataSources && viewItem == dataSource",
          "group": "inline"
        },
        {
          "command": "repoLens.editToolFromTree",
          "when": "view == repoLens.tools && viewItem == tool",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repoLens",
          "title": "RepoLens",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "repoLens": [
        {
          "id": "repoLens.embedding",
          "name": "Embedding"
        },
        {
          "id": "repoLens.dataSources",
          "name": "Data Sources"
        },
        {
          "id": "repoLens.tools",
          "name": "Tools"
        }
      ]
    },
    "configuration": {
      "title": "RepoLens",
      "properties": {
        "repoLens.embedding.provider": {
          "type": "string",
          "enum": [
            "openai"
          ],
          "default": "openai",
          "description": "Embedding provider to use for indexing."
        },
        "repoLens.embedding.openai.model": {
          "type": "string",
          "default": "text-embedding-3-small",
          "description": "OpenAI embedding model to use."
        },
        "repoLens.embedding.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for OpenAI-compatible API (for proxies or compatible services)."
        },
        "repoLens.search.topK": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Number of chunks to return per tool query."
        },
        "repoLens.sync.onStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync data sources marked 'onStartup' when VS Code launches."
        },
        "repoLens.log.level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Logging verbosity."
        }
      }
    },
    "languageModelTools": [
      {
        "name": "repolens-search",
        "toolReferenceName": "repolens",
        "tags": ["repolens", "search", "rag", "github", "codebase"],
        "displayName": "RepoLens: Search Repositories",
        "userDescription": "Search your indexed GitHub repositories for relevant code, documentation, or knowledge.",
        "modelDescription": "Search indexed GitHub repositories using vector similarity. Returns relevant code snippets and documentation. Optionally filter by a specific repository (owner/repo format). Use this whenever the user asks about a specific codebase, library, or repository that may be indexed.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Natural language search query describing what you're looking for."
            },
            "repository": {
              "type": "string",
              "description": "Optional: filter to a specific indexed repository in 'owner/repo' format (e.g. 'vercel/next.js'). Omit to search all indexed repositories."
            }
          },
          "required": ["query"]
        }
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "dev:install": "bash scripts/dev-install.sh",
    "rebuild:native": "electron-rebuild -v 39.8.3 --arch arm64 --only better-sqlite3,sqlite-vec"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "minimatch": "^10.0.1",
    "sqlite-vec": "^0.1.6",
    "tiktoken": "^1.0.18"
  },
  "optionalDependencies": {
    "sqlite-vec-darwin-arm64": "^0.1.9",
    "sqlite-vec-darwin-x64": "^0.1.9",
    "sqlite-vec-linux-x64": "^0.1.9",
    "sqlite-vec-linux-arm64": "^0.1.9",
    "sqlite-vec-windows-x64": "^0.1.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
